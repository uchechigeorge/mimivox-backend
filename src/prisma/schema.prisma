// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// =====================
/// USER MODULE
/// =====================

model User {
  id                         String         @id @default(uuid()) @db.VarChar(1024)
  email                      String         @unique
  emailVerified              Boolean        @default(false)
  firstName                  String         @db.VarChar(1024)
  lastName                   String         @db.VarChar(1024)
  fullName                   String         @default("") @db.VarChar(1024)
  password                   String         @db.VarChar(1024)
  dpUrl                      String?        @db.VarChar(1024)
  defaultBg                  String?        @db.VarChar(1024)
  phoneNumber                String?        @db.VarChar(1024)
  hasActiveSubscription      Boolean        @default(false)
  noOfCreditsUsed            Int            @default(0)
  totalCreditsUsed           Int            @default(0)
  noOfCreditsAllocated       Int?           @default(0)
  noOfCreditsLeft            Int?           @default(0)
  noOfCharactersUsed         Int            @default(0)
  totalCharactersUsed        Int            @default(0)
  noOfCharactersAllocated    Int?           @default(0)
  noOfCharactersLeft         Int?           @default(0)
  noOfVoicesUsed             Int            @default(0)
  noOfWordsAllowed           Int?           @default(0)
  totalVoicesUsed            Int            @default(0)
  noOfVoicesAllocated        Int?           @default(0)
  noOfVoicesLeft             Int?           @default(0)
  noOfCloneVoicesUsed        Int            @default(0)
  totalCloneVoicesUsed       Int            @default(0)
  noOfCloneVoicesAllocated   Int?           @default(0)
  noOfCloneVoicesLeft        Int?           @default(0)
  noOfPremiumVoicesUsed      Int            @default(0)
  totalPremiumVoicesUsed     Int            @default(0)
  noOfPremiumVoicesAllocated Int?           @default(0)
  noOfPremiumVoicesLeft      Int?           @default(0)
  noOfMusicUsed              Int            @default(0)
  totalMusicUsed             Int            @default(0)
  noOfMusicAllocated         Int?           @default(0)
  noOfMusicLeft              Int?           @default(0)
  noOfImagesUsed             Int            @default(0)
  totalImagesUsed            Int            @default(0)
  noOfImagesAllocated        Int?           @default(0)
  noOfImagesLeft             Int?           @default(0)
  noOfVideosUsed             Int            @default(0)
  totalVideosUsed            Int            @default(0)
  noOfVideosAllocated        Int?           @default(0)
  noOfVideosLeft             Int?           @default(0)
  blocked                    Boolean        @default(false)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  deletedAt                  DateTime?
  subscriptions              Subscription[]
  voices                     Voice[]
  audios                     Audio[]
  images                     Image[]
  music                      Music[]
  videos                     Video[]

  @@map("Users")
}

model Admin {
  id            String    @id @default(uuid()) @db.VarChar(1024)
  email         String    @unique
  emailVerified Boolean   @default(false)
  firstName     String    @db.VarChar(1024)
  lastName      String    @db.VarChar(1024)
  fullName      String    @default("") @db.VarChar(1024)
  password      String    @db.VarChar(1024)
  dpUrl         String?   @db.VarChar(1024)
  defaultBg     String?   @db.VarChar(1024)
  phoneNumber   String?   @db.VarChar(1024)
  blocked       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@map("Admins")
}

/// =====================
/// BILLING MODULE
/// =====================

model Plan {
  id            String         @id @default(uuid()) @db.VarChar(1024)
  name          String         @db.VarChar(1024)
  description   String?        @db.VarChar(1024)
  slug          String         @unique @db.VarChar(1024)
  isFree        Boolean        @default(false)
  sequence      Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  pricings      Pricing[]
  subscriptions Subscription[]
  settings      PlanSetting?

  @@map("Plans")
}

model PlanSetting {
  id                          String    @id @default(uuid()) @db.VarChar(1024)
  planId                      String    @unique
  planName                    String    @db.VarChar(1024)
  noOfCredits                 Int?      @default(0)
  noOfCharacters              Int?      @default(0)
  noOfWords                   Int?      @default(0)
  noOfVoices                  Int?      @default(0)
  noOfPremiumVoices           Int?      @default(0)
  noOfCloneVoices             Int?      @default(0)
  noOfMusic                   Int?      @default(0)
  noOfImages                  Int?      @default(0)
  noOfVideos                  Int?      @default(0)
  hasCommunitySupport         Boolean   @default(true)
  hasEmailSupport             Boolean   @default(false)
  socialMediaGuidelines       Int       @default(1)
  hasDedicatedCustomerSupport Boolean   @default(false)
  hasApiAccess                Boolean   @default(false)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  deletedAt                   DateTime?
  plan                        Plan      @relation(fields: [planId], references: [id])

  @@map("PlanSettings")
}

enum IntervalType {
  None
  Year
  Month
  Week
  Day
}

model Pricing {
  id            String         @id @default(uuid()) @db.VarChar(1024)
  planId        String         @db.VarChar(1024)
  planName      String         @db.VarChar(1024)
  slug          String         @unique @db.VarChar(1024)
  name          String         @db.VarChar(1024)
  description   String?        @db.VarChar(1024)
  price         Decimal        @db.Decimal(18, 2)
  oldPrice      Decimal?       @db.Decimal(18, 2)
  interval      String         @db.VarChar(1024)
  intervalCount Int
  intervalType  IntervalType   @default(None)
  sequence      Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  plan          Plan           @relation(fields: [planId], references: [id])
  subscriptions Subscription[]

  @@map("Pricings")
}

enum SubscriptionStatus {
  Pending
  WillRenew
  Completed
  Cancelled
  PastDue
  Trialing
}

enum PaymentGatewayOption {
  None
  Manual
  Paystack
}

model Subscription {
  id                   String                @id @default(uuid()) @db.VarChar(1024)
  reference            String                @db.VarChar(1024)
  userId               String                @db.VarChar(1024)
  userName             String                @db.VarChar(1024)
  pricingId            String                @db.VarChar(1024)
  pricingName          String                @db.VarChar(1024)
  planId               String                @db.VarChar(1024)
  planName             String                @db.VarChar(1024)
  isActive             Boolean
  status               SubscriptionStatus    @default(Pending)
  startDate            DateTime
  nextBillingDate      DateTime?
  endDate              DateTime?
  initialAmount        Decimal?              @db.Decimal(18, 2)
  paymentGateway       PaymentGatewayOption  @default(None)
  user                 User                  @relation(fields: [userId], references: [id])
  pricing              Pricing               @relation(fields: [pricingId], references: [id])
  plan                 Plan                  @relation(fields: [planId], references: [id])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  subscriptionPayments SubscriptionPayment[]

  @@map("Subscriptions")
}

model SubscriptionPayment {
  id                    String               @id @default(uuid()) @db.Uuid()
  subscriptionId        String?              @db.VarChar(1024)
  subscriptionReference String               @db.VarChar(1024)
  amount                Decimal              @db.Decimal(18, 2)
  isInitialPayment      Boolean              @default(false)
  isPaymentVerified     Boolean              @default(false)
  paymentGateway        PaymentGatewayOption @default(None)
  paidAt                DateTime?
  updatedAt             DateTime             @updatedAt
  createdAt             DateTime             @default(now())
  deletedAt             DateTime?
  subscription          Subscription?        @relation(fields: [subscriptionId], references: [id])

  @@map("SubscriptionPayments")
}

/// =====================
/// AUDIO MODULE
/// =====================

enum VoiceType {
  Default
  Cloned
}

enum AudioServiceType {
  None
  Google
  ElevenLabs
  Noiz
}

model Voice {
  id                      String           @id @default(uuid()) @db.VarChar(1024)
  name                    String           @db.VarChar(1024)
  description             String?          @db.VarChar(1024)
  type                    VoiceType        @default(Cloned)
  userId                  String?          @db.VarChar(1024)
  userName                String?          @db.VarChar(1024)
  gender                  String?          @db.VarChar(1024)
  audioServiceReferenceId String?          @db.VarChar(1024)
  audioServiceType        AudioServiceType
  previewUrl              String?          @db.VarChar(1024)
  sampleUrl               String?          @db.VarChar(1024)
  sequence                Int              @default(0)
  audioServiceRequestLog  Json?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  deletedAt               DateTime?
  audios                  Audio[]
  user                    User?            @relation(fields: [userId], references: [id])

  @@unique([audioServiceType, audioServiceReferenceId])
  @@map("Voices")
}

model Audio {
  id                     String           @id @default(uuid()) @db.VarChar(1024)
  userId                 String           @db.VarChar(1024)
  userName               String           @db.VarChar(1024)
  content                String
  languageCode           String           @default("en-US") @db.VarChar(1024)
  voiceId                String           @db.VarChar(1024)
  voiceName              String           @db.VarChar(1024)
  audioUrl               String?          @db.VarChar(1024)
  audioServiceType       AudioServiceType @default(None)
  audioServiceRequestLog Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?
  user                   User             @relation(fields: [userId], references: [id])
  voice                  Voice            @relation(fields: [voiceId], references: [id])

  @@map("Audios")
}

enum ImageServiceType {
  None
  Xai
}

model Image {
  id                     String           @id @default(uuid()) @db.Uuid()
  userId                 String?          @db.VarChar(1024)
  userName               String?          @db.VarChar(1024)
  title                  String           @db.VarChar(1024)
  prompt                 String           @db.VarChar(1024)
  url                    String?          @db.VarChar(1024)
  altUrl                 String?          @db.VarChar(1024)
  imageServiceType       ImageServiceType @default(None)
  imageServiceRequestLog Json?
  updatedAt              DateTime         @updatedAt
  createdAt              DateTime         @default(now())
  deletedAt              DateTime?
  user                   User?            @relation(fields: [userId], references: [id])

  @@map("Images")
}

enum TaskType {
  None
  Music
  Video
}

enum TaskStatus {
  Pending
  Started
  Completed
}

enum TaskServiceOption {
  None
  Suno
  Xai
}

model Task {
  id                String            @id @default(uuid()) @db.Uuid()
  referenceId       String            @db.VarChar(1024)
  userId            String?           @db.VarChar(1024)
  userName          String?           @db.VarChar(1024)
  type              TaskType          @default(None)
  status            TaskStatus        @default(Pending)
  progress          Int? // (0–100)
  resultUrl         String?
  errorMessage      String?
  serviceOption     TaskServiceOption @default(None)
  serviceRequestLog Json?
  retryCount        Int               @default(0)
  maxRetries        Int               @default(5)
  lockedAt          DateTime? // for worker locking
  lockedBy          String? // worker id
  nextRunAt         DateTime? // for scheduling retries
  completedAt       DateTime?
  updatedAt         DateTime          @updatedAt
  createdAt         DateTime          @default(now())
  deletedAt         DateTime?
  music             Music[]
  videos            Video[]

  @@map("Tasks")
}

enum MusicServiceType {
  None
  Suno
}

model Music {
  id                      String           @id @default(uuid()) @db.Uuid()
  userId                  String?          @db.VarChar(1024)
  userName                String?          @db.VarChar(1024)
  title                   String           @db.VarChar(1024)
  prompt                  String           @db.VarChar(1024)
  audioUrl                String?          @db.VarChar(1024)
  audioAltUrl             String?          @db.VarChar(1024)
  streamAudioUrl          String?          @db.VarChar(1024)
  streamAudioAltUrl       String?          @db.VarChar(1024)
  imageUrl                String?          @db.VarChar(1024)
  imageAltUrl             String?          @db.VarChar(1024)
  durationInSeconds       Int?
  musicServiceReferenceId String?          @db.VarChar(1024)
  musicServiceType        MusicServiceType @default(None)
  musicServiceRequestLog  Json?
  taskId                  String?          @db.Uuid()
  updatedAt               DateTime         @updatedAt
  createdAt               DateTime         @default(now())
  deletedAt               DateTime?
  user                    User?            @relation(fields: [userId], references: [id])
  task                    Task?            @relation(fields: [taskId], references: [id])

  @@map("Musics")
}

enum VideoServiceType {
  None
  Xai
}

model Video {
  id                      String           @id @default(uuid()) @db.Uuid()
  userId                  String?          @db.VarChar(1024)
  userName                String?          @db.VarChar(1024)
  title                   String           @db.VarChar(1024)
  prompt                  String           @db.VarChar(1024)
  url                     String?          @db.VarChar(1024)
  altUrl                  String?          @db.VarChar(1024)
  thumbnailUrl            String?          @db.VarChar(1024)
  durationInSeconds       Int?
  videoServiceReferenceId String?          @db.VarChar(1024)
  videoServiceType        VideoServiceType @default(None)
  videoServiceRequestLog  Json?
  taskId                  String?          @db.Uuid()
  updatedAt               DateTime         @updatedAt
  createdAt               DateTime         @default(now())
  deletedAt               DateTime?
  user                    User?            @relation(fields: [userId], references: [id])
  task                    Task?            @relation(fields: [taskId], references: [id])

  @@map("Videos")
}
